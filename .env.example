# ─── LOCAL ───────────────────────────────────────────────────────────────────
# En local el proxy resuelve a localhost:8080 via BACKEND_URL.
# NEXT_PUBLIC_API_URL se deja vacío para que lib/api.ts use el default '/api/proxy'.
NEXT_PUBLIC_APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8080

# ─── STAGE (Vercel — rama develop) ───────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://stage.accesosport.com
# BACKEND_URL=https://api-stage.accesosport.com

# ─── PRODUCTION (Vercel — rama main) ─────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://accesosport.com
# BACKEND_URL=https://api.accesosport.com
